#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
MODE="${1:---tracked}"

usage() {
  cat <<'EOF'
Usage: scripts/scan-secrets [--tracked|--staged]

Scans repository text files for high-confidence credential patterns without
printing matched secret values.

  --tracked  scan all tracked files in the working tree (default)
  --staged   scan staged file contents from the Git index
EOF
}

if [[ "$MODE" != "--tracked" && "$MODE" != "--staged" ]]; then
  usage >&2
  exit 2
fi

cd "$ROOT_DIR"

TMP_DIR="$(mktemp -d)"
ERRORS_FILE="$TMP_DIR/errors"
trap 'rm -rf "$TMP_DIR"' EXIT

is_skippable_path() {
  case "$1" in
    *.appiconset/*|*.colorset/*|*.png|*.jpg|*.jpeg|*.gif|*.pdf|*.zip|*.gz|*.xcuserstate)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

scan_file() {
  local display_path="$1"
  local content_path="$2"

  if ! LC_ALL=C grep -Iq . "$content_path"; then
    return 0
  fi

  DISPLAY_PATH="$display_path" perl -ne '
    BEGIN {
      @rules = (
        ["google-api-key", qr/AIza[0-9A-Za-z_-]{20,}/],
        ["openai-api-key", qr/sk-(?:proj-)?[A-Za-z0-9_-]{20,}/],
        ["github-token", qr/gh[pousr]_[A-Za-z0-9_]{20,}/],
        ["slack-token", qr/xox[baprs]-[A-Za-z0-9-]{20,}/],
        ["aws-access-key-id", qr/\b(?:AKIA|ASIA)[0-9A-Z]{16}\b/],
        ["private-key-block", qr/-----BEGIN (?:RSA |DSA |EC |OPENSSH )?PRIVATE KEY-----/],
      );
    }

    for my $rule (@rules) {
      if ($_ =~ $rule->[1]) {
        print "$ENV{DISPLAY_PATH}:$.: $rule->[0]\n";
      }
    }
  ' "$content_path"

  case "$display_path" in
    *.xcscheme)
      DISPLAY_PATH="$display_path" perl -0ne '
        while (/<EnvironmentVariable\b(?:(?!<\/EnvironmentVariable>).)*?key\s*=\s*"([^"]*(?:API_KEY|TOKEN|SECRET)[^"]*)"(?:(?!<\/EnvironmentVariable>).)*?value\s*=\s*"([^"]+)"(?:(?!<\/EnvironmentVariable>).)*?>/sg) {
          my $line = 1 + (substr($_, 0, $-[0]) =~ tr/\n//);
          print "$ENV{DISPLAY_PATH}:$line: non-empty secret-like Xcode scheme environment variable ($1)\n";
        }
      ' "$content_path"
      ;;
  esac
}

scan_path() {
  local path="$1"
  local content_path="$TMP_DIR/content"

  if is_skippable_path "$path"; then
    return 0
  fi

  if [[ "$MODE" == "--staged" ]]; then
    git show ":$path" > "$content_path" 2>/dev/null || return 0
  else
    [[ -f "$path" ]] || return 0
    cp "$path" "$content_path"
  fi

  scan_file "$path" "$content_path" >> "$ERRORS_FILE"
}

if [[ "$MODE" == "--staged" ]]; then
  while IFS= read -r -d '' path; do
    scan_path "$path"
  done < <(git diff --cached --name-only -z --diff-filter=ACMR)
else
  while IFS= read -r -d '' path; do
    scan_path "$path"
  done < <(git ls-files -z)
fi

if [[ -s "$ERRORS_FILE" ]]; then
  echo "Likely secret material found. Rotate any exposed credential and remove it before committing." >&2
  echo "Matches are reported by rule only; secret values are intentionally not printed." >&2
  cat "$ERRORS_FILE" >&2
  exit 1
fi

echo "No likely secrets found in ${MODE#--} files."
